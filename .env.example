# AI Mobile Team Configuration

# Server
PORT=3001
NODE_ENV=development

# Database (共用 main platform 的資料庫)
DATABASE_URL=mysql://root:password@localhost:3306/sowork_ai

# JWT (需與 main platform 相同以共用 session)
