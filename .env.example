# AI Mobile Team Environment Variables

# Server
PORT=3001
NODE_ENV=development

# Database (共用 sowork-ai-v2 的資料庫)
DATABASE_URL=mysql://user:password@host:3306/sowork

# JWT Secret (共用 main platform session)
JWT_SECRET=your-jwt-secret-here

# CORS
CORS_ORIGIN=http://localhost:3001,https://mobileteam.sowork.ai,https://dev-mobileteam.sowork.ai
